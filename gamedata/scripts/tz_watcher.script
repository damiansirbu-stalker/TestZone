-- Event counters (fire counts)
local stats = {}
for _, cb in pairs(ALL_CALLBACKS) do
    stats[cb] = 0
end

-- Config state
local config = {
    enabled = false,
    periodic_stats_enabled = false,
    periodic_stats_interval_sec = 300,
    log_payload_enabled = true,
    deep_introspect_enabled = true,
    introspect_depth = 3,
    rate_limit_enabled = true,
    rate_limit_interval_ms = 500,
}

--- Format dispatch table (reduces if/elseif chain)
local format_dispatch = {
    userdata = function(arg, deep)
        if deep then return format_userdata_deep(arg) end
        local raw_id = arg.id
        local id = type(raw_id) == "function" and raw_id(arg) or raw_id
        return (id and id ~= INVALID_ENTITY_ID) and ("obj#" .. id) or "userdata"
    end,
    table = function(arg, deep)
        if deep then return format_table(arg, 1, config.introspect_depth or 2) end
        local size = 0
        for _ in pairs(arg) do size = size + 1 end
        return "table[" .. size .. "]"
    end,
    string = function(arg)
        local truncated = arg:sub(1, 64)
        return "\"" .. truncated .. (arg:len() > 64 and "..." or "") .. "\""
    end,
    boolean = function(arg) return arg and "true" or "false" end,
    number = function(arg)
        return arg == math_floor(arg) and tostring(arg) or string_format("%.4f", arg)
    end,
    ["nil"] = function() return "nil" end,
    ["function"] = function() return "function" end,
}

--- Format single argument (shallow or deep based on config)
local function format_arg(arg, deep)
    local formatter = format_dispatch[type(arg)]
    return formatter and formatter(arg, deep) or tostring(arg)
end

--- Format all arguments with positional labels
--- Output: arg1=value, arg2=value, ...
local function format_args(deep, ...)
    local args = {...}
    local parts = {}
    for i = 1, #args do
        parts[#parts + 1] = "arg" .. i .. "=" .. format_arg(args[i], deep)
    end
    return table_concat(parts, ", ")
end

--- Check rate limit for callback
local function should_log(callback_name)
    if not config.rate_limit_enabled then return true end
    local now = time_global()
    local last = last_log_time[callback_name] or 0
    local interval = config.rate_limit_interval_ms or 1000
    if now - last < interval then return false end
    last_log_time[callback_name] = now
    return true
end

--- Attempt to read .online field from first arg (squad server_object)
--- Returns "online", "offline", or nil if not applicable/readable
--- @safety SAFE - type-guarded, no pcall needed (field access on luabind is safe, returns nil if missing)
local function read_online_status(first_arg)
    if type(first_arg) ~= "userdata" then return nil end
    local val = first_arg.online
    if val == true then return "online" end
    if val == false then return "offline" end
    return nil
end

--- Squad callback names where online status is useful
local SQUAD_CALLBACKS = {
    squad_on_update = true,
    squad_on_first_update = true,
    squad_on_enter_smart = true,
    squad_on_leave_smart = true,
    squad_on_npc_death = true,
    squad_on_npc_creation = true,
    squad_on_add_npc = true,
    squad_on_after_game_vertex_change = true,
    squad_on_after_level_change = true,
}

local function create_handler(callback_name)
    local is_squad_cb = SQUAD_CALLBACKS[callback_name]
    return function(...)
        if not config.enabled then return end
        stats[callback_name] = stats[callback_name] + 1
        if config.log_payload_enabled and should_log(callback_name) then
            local deep = config.deep_introspect_enabled
            local arg_str = format_args(deep, ...)
            local suffix = ""
            if is_squad_cb then
                local status = read_online_status(select(1, ...))
                if status then suffix = " [" .. status .. "]" end
            end
            log.info("[%s] %s%s", callback_name, arg_str, suffix)
        end
    end
end

--- @export console: tz_watcher.get_stats()
function get_stats()
    local result = {}
    for callback, count in pairs(stats) do
        if count > 0 then
            result[callback] = count
        end
    end
    return result
end

--- @export console: tz_watcher.print_fired()
function print_fired()
    local fired = {}
    for callback, count in pairs(stats) do
        if count > 0 then
            fired[#fired + 1] = {name = callback, count = count}
        end
    end
    table_sort(fired, function(a, b) return a.count > b.count end)

    log.info("=== CALLBACKS FIRED (%d total) ===", #fired)
    for _, item in ipairs(fired) do
        log.info("  %6d  %s", item.count, item.name)
    end
    log.info("=== END ===")
end

--- @export console: tz_watcher.print_never_fired()
function print_never_fired()
    local never = {}
    for _, cb in pairs(ALL_CALLBACKS) do
        if stats[cb] == 0 then
            never[#never + 1] = cb
        end
    end

    log.info("=== NEVER FIRED (%d callbacks) ===", #never)
    for _, cb in ipairs(never) do
        log.info("  %s", cb)
    end
    log.info("=== END ===")
end

--- Log periodic statistics
local function log_periodic_stats()
    if not config.periodic_stats_enabled then return end

    local fired = {}
    for callback, count in pairs(stats) do
        if count > 0 then
            fired[#fired + 1] = {name = callback, count = count}
        end
    end
    table_sort(fired, function(a, b) return a.count > b.count end)

    log.info("=== PERIODIC STATS (%d active) ===", #fired)
    for _, item in ipairs(fired) do
        log.info("  %10d  %s", item.count, item.name)
    end
    log.info("=== END STATS ===")
end

--- @safety pcall: some callbacks may not exist in engine
function on_game_start()
    log.info("TestZone v%s (xlibs v%s)", _tz_deps.get_version(), xlibs.get_version())
    log.info("TestZone Watcher initialized (162 callbacks)")

    -- Register all callbacks
    local registered = 0
    local failed = 0
    for _, callback_name in pairs(ALL_CALLBACKS) do
        local handler = create_handler(callback_name)
        local ok, _ = pcall(RegisterScriptCallback, callback_name, handler)
        if ok then
            registered = registered + 1
        else
            failed = failed + 1
        end
    end

    log.info("Registered %d callbacks (%d failed)", registered, failed)

    -- Periodic stats timer
    local function timer_periodic_stats()
        log_periodic_stats()
        ResetTimeEvent("tz_watcher", "periodic_stats", config.periodic_stats_interval_sec)
    end

    CreateTimeEvent("tz_watcher", "periodic_stats", config.periodic_stats_interval_sec, timer_periodic_stats)

    -- Config loader
    local cfg = tz_mcm and tz_mcm.cfg
    local function load_config()
        if not cfg then return end
        config.enabled = cfg.watcher_enabled
        config.periodic_stats_enabled = cfg.periodic_stats_enabled
        config.periodic_stats_interval_sec = cfg.periodic_stats_interval
        config.log_payload_enabled = cfg.log_payload_enabled
        config.deep_introspect_enabled = cfg.deep_introspect_enabled
        config.introspect_depth = cfg.introspect_depth
        config.rate_limit_enabled = cfg.rate_limit_enabled
        config.rate_limit_interval_ms = cfg.rate_limit_interval
    end

    -- Reload config on MCM change
    RegisterScriptCallback("on_option_change", function()
        load_config()
        -- Reschedule timer if interval changed
        RemoveTimeEvent("tz_watcher", "periodic_stats")
        CreateTimeEvent("tz_watcher", "periodic_stats", config.periodic_stats_interval_sec, function()
            log_periodic_stats()
            return true
        end)
    end)

    -- Load initial config
    load_config()
end
