--- tz_watcher: A-Life callback monitoring with fire counts and payload logging

local pairs, ipairs, tostring, pcall, type, time_global = pairs, ipairs, tostring, pcall, type, time_global
local math_floor, string_format, table_concat, table_sort = math.floor, string.format, table.concat, table.sort
local RegisterScriptCallback = RegisterScriptCallback
local INVALID_ENTITY_ID = xconst.INVALID_ENTITY_ID

local log = xlog.get_logger("TestZone.watcher", { outfile = "testzone.log" })

-- Rate limiting state
local last_log_time = {}

-- Use xinspect for formatting (with local aliases for performance)
local format_table = xinspect.format_table
local format_userdata_deep = xinspect.userdata

